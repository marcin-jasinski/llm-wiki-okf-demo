# Where the wiki bundle and the raw sources live (typically side by side in
# one git repo you manage; the agent never runs git).
WIKI_DIR=/path/to/wiki-repo/wiki
RAW_SOURCES_DIR=/path/to/wiki-repo/raw

# LLM backend: openrouter | lmstudio (ADR 0003 — same client, different base_url)
LLM_BACKEND=openrouter
MODEL_NAME=anthropic/claude-sonnet-4.5
OPENROUTER_API_KEY=sk-or-...
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Wiki storage backend: local | xwiki (ADR 0011)
WIKI_BACKEND=local

# xWiki backend (only needed when WIKI_BACKEND=xwiki). The agent spawns our
# thin xWiki MCP server (ADR 0011) and writes OKF pages into XWIKI_SPACE
# (ADR 0012 — the write sandbox, mapped verbatim as markdown/1.2 pages).
XWIKI_BASE_URL=http://localhost:8080
XWIKI_USER=superadmin
XWIKI_PASSWORD=xwiki-demo
XWIKI_SPACE=WikiDemo
# XWIKI_WIKI=xwiki   # wiki name, defaults to "xwiki"
